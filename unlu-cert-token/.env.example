# Base Sepolia RPC URL (e.g., Alchemy, Infura, or public RPC)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Private key of the deployer account (WITHOUT the 0x prefix)
# WARNING: Do not commit your actual private key or .env file to Git!
PRIVATE_KEY=your_private_key_here

# Basescan API Key for contract verification
# Obtain one from https://basescan.org
BASESCAN_API_KEY=your_basescan_api_key_here
